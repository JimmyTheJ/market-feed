# Pipeline scheduling
PIPELINE_RUN_HOUR=6
PIPELINE_RUN_MINUTE=30
PIPELINE_TIMEZONE=America/New_York

# Ollama settings (adjust host for docker: use host.docker.internal or your server IP)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
USE_OLLAMA=true

# API server settings
API_HOST=0.0.0.0
API_PORT=8000

# Paths (relative to project root inside container)
POSITIONS_PATH=
OUTPUT_BASE_PATH=output

# Docker network name (must be created externally: docker network create proxy)
DOCKER_NETWORK=proxy

# ── Authentication ──────────────────────────────────────────────────
# Set AUTH_ENABLED=true to require LDAP login
AUTH_ENABLED=false

# LDAP server connection
LDAP_SERVER=ldap://ldap-server:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_DN_TEMPLATE=uid={username},ou=users,dc=example,dc=com
# Auth method: "direct" (bind with DN template) or "search" (search then bind)
LDAP_AUTH_METHOD=direct
# Service account for search mode (not needed for direct bind)
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
# Optional: restrict to members of this group
LDAP_GROUP_DN=
LDAP_USE_TLS=false
LDAP_SEARCH_FILTER=(uid={username})

# JWT session tokens
JWT_SECRET=change-this-to-a-random-secret-string
JWT_EXPIRY_HOURS=24
SESSION_COOKIE_NAME=mp_session
# Set true when behind HTTPS (via Nginx Proxy Manager)
COOKIE_SECURE=false

# Brute force protection
MAX_LOGIN_ATTEMPTS_PER_IP=5
IP_LOCKOUT_MINUTES=15
MAX_LOGIN_ATTEMPTS_PER_USER=10
USER_LOCKOUT_MINUTES=30

# Optional: external news API key
# NEWS_API_KEY=your_key_here
